# =============================================================================
# Akram Perfumes — environment variables
# =============================================================================
# Copy to `.env.local` and fill in the values from your Supabase project
# (Project Settings → API). Never commit `.env.local` or real keys.

# Public — safe to expose to the browser (protected by Row Level Security).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret — SERVER ONLY. Bypasses RLS. Used for seeding and privileged
# server-side operations (e.g. order writes after Razorpay verification).
# Must never be exposed to the client or committed.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Razorpay (next phase — not used yet). Placeholders so the payment integration
# drops in without further env changes.
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
